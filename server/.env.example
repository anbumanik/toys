# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/ecommerce?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Admin bootstrap (used only for the /api/auth/seed-admin one-time script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Cloudflare Images
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_IMAGES_API_TOKEN=your_api_token_with_images_write_permission
CLOUDFLARE_IMAGES_ACCOUNT_HASH=your_delivery_account_hash
CLOUDFLARE_IMAGES_VARIANT_DEFAULT=public
CLOUDFLARE_IMAGES_VARIANT_THUMB=thumbnail
